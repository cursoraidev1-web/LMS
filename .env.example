# Server
NODE_ENV=development
PORT=4000
API_PREFIX=/api/v1
# Optional: full API base URL for Swagger "Try it out" (e.g. https://api.yourdomain.com/api/v1). Used in OpenAPI spec when serving /openapi.yaml.
# PUBLIC_API_URL=https://api.yourdomain.com/api/v1

# MongoDB (required)
MONGODB_URI=mongodb://localhost:27017/lms-cbt

# Redis (required for sessions, cache, rate-limit)
REDIS_URI=redis://localhost:6379

# JWT (min 16 chars; use 32+ in production)
JWT_ACCESS_SECRET=your-access-secret-min-16-chars
JWT_REFRESH_SECRET=your-refresh-secret-min-16-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Bcrypt (cost 10–12; 12 for high security)
BCRYPT_ROUNDS=12

# Rate limit (per IP)
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100

# CORS (comma-separated origins; * for dev only)
CORS_ORIGINS=http://localhost:3000,https://yourdomain.com

# Log level: trace, debug, info, warn, error
LOG_LEVEL=info
