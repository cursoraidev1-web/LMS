{
  "name": "lms-cbt-backend",
  "version": "1.0.0",
  "description": "Production-ready CBT API - fast, secure, multi-tenant",
  "main": "dist/server.js",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "build:render": "npm install --include=dev && npm run build",
    "start": "node dist/server.js",
    "seed": "tsx scripts/seed.ts",
    "lint": "eslint src --ext .ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "bcrypt": "^5.1.1",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^7.4.0",
    "helmet": "^7.1.0",
    "hpp": "^0.2.3",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "mongodb": "^7.1.0",
    "mongoose": "^8.8.0",
    "multer": "^2.0.2",
    "nodemailer": "^8.0.1",
    "pino": "^9.5.0",
    "pino-http": "^10.2.0",
    "pino-pretty": "^11.3.0",
    "qrcode": "^1.5.4",
    "speakeasy": "^2.0.0",
    "swagger-ui-express": "^5.0.1",
    "xlsx": "^0.18.5",
    "zod": "^3.23.8",
    "@types/bcrypt": "^5.0.2",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.25",
    "@types/hpp": "^0.2.7",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.0.0",
    "@types/node": "^22.19.13",
    "@types/nodemailer": "^7.0.11",
    "@types/qrcode": "^1.5.6",
    "@types/speakeasy": "^2.0.10",
    "@types/swagger-ui-express": "^4.1.8",
    "typescript": "^5.6.3"
  },
  "devDependencies": {
    "@types/supertest": "^6.0.0",
    "supertest": "^7.0.0",
    "tsx": "^4.19.2",
    "vitest": "^2.1.4"
  }
}
